function doPost(e) {
  try {
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Form Responses 1");

    const club = (e.parameter.club || "").trim();
    const lat = (e.parameter.lat || "").trim();
    const lng = (e.parameter.lng || "").trim();
    const paddlers = (e.parameter.paddlers || "").trim();
    const photo = (e.parameter.photo || "").trim();

    if (!club || !lat || !lng || !paddlers) {
      return ContentService
        .createTextOutput("Missing required fields")
        .setMimeType(ContentService.MimeType.TEXT);
    }

    const timestamp = new Date();

    // Columns:
    // A Timestamp
    // B Club / Group Name
    // C Drop a pin
    // D unused
    // E Latitude
    // F Longitude
    // G Number of paddlers
    // H Optional photo link

    sheet.appendRow([
      timestamp,
      club,
      lat + "," + lng,
      "",
      lat,
      lng,
      paddlers,
      photo
    ]);

    return ContentService
      .createTextOutput("Success")
      .setMimeType(ContentService.MimeType.TEXT);

  } catch (err) {
    return ContentService
      .createTextOutput("Error: " + err.message)
      .setMimeType(ContentService.MimeType.TEXT);
  }
}
